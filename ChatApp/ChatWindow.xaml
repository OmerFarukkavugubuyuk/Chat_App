<Window x:Class="ChatApp.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN Sohbet" Height="520" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e" Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="#a6e3a1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Foreground="#cdd6f4" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="Scroller" VerticalScrollBarVisibility="Auto"
                      Margin="0" Background="#1e1e2e">
            <ItemsControl x:Name="MessageList" Margin="12,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#cdd6f4" FontSize="13"
                                   Margin="0,3" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input -->
        <Border Grid.Row="2" Background="#181825" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Grid.Column="0"
                         Background="#313244" Foreground="#cdd6f4"
                         BorderBrush="#45475a" Padding="8,6"
                         FontSize="13" Margin="0,0,8,0"
                         KeyDown="InputBox_KeyDown"/>
                <Button Grid.Column="1" Content="Gönder" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
